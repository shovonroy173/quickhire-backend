{
  "name": "quickhire-backend",
  "version": "1.0.0",
  "description": "Backend API for QuickHire Job Board Application",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
